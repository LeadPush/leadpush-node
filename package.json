{
  "name": "@leadpush/sdk-node",
  "version": "1.0.8",
  "description": "",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rm -rf dist .rollup",
    "prebuild": "pnpm run clean",
    "build": "tsc -p tsconfig.build.json && rollup -c && rm -rf .rollup",
    "changeset": "changeset",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "prepack": "pnpm run build",
    "release": "changeset publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "version": "changeset version"
  },
  "repository": {
    "url": "https://github.com/LeadPush/leadpush-node"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.21.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "rollup": "^4.60.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
